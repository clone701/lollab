{
  "enabled": true,
  "name": "Python Code Quality Check on Save",
  "description": "Pythonファイル保存時にflake8, black, isort, mypyでコード品質をチェック",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd backend && flake8 . && black --check . && isort --check-only . && mypy .",
    "timeout": 60
  }
}

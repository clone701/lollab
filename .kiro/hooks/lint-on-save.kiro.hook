{
  "enabled": true,
  "name": "Frontend Code Quality Check on Save",
  "description": "TypeScriptファイル保存時にESLintを実行",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "frontend/**/*.ts",
      "frontend/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint",
    "timeout": 60,
    "cwd": "frontend"
  }
}

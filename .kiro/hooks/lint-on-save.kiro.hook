{
  "enabled": true,
  "name": "Frontend Code Quality Check on Save",
  "description": "TypeScriptファイル保存時にgetDiagnosticsで診断を実行",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "frontend/**/*.ts",
      "frontend/**/*.tsx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "保存されたファイルに対してgetDiagnosticsツールを実行し、型エラー・lint警告・その他の問題をチェックしてください。問題があれば報告し、なければ「問題なし」と簡潔に返答してください。"
  }
}
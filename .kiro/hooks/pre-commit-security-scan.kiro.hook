{
  "enabled": false,
  "name": "Pre-Commit Security Scan",
  "description": "コミット前にPythonコードのセキュリティ脆弱性をスキャン（bandit）- 現在無効化",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "banditでセキュリティスキャンを実行してください。問題があれば報告し、なければコミットを続行してください。"
  }
}

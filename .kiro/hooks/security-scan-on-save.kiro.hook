{
  "enabled": true,
  "name": "Security Scan on Python Save",
  "description": "Pythonファイル保存時にbanditでセキュリティ脆弱性をスキャン",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "bandit -r backend -f txt --severity-level medium --confidence-level medium || exit 0",
    "timeout": 60
  }
}

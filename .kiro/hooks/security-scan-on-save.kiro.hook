{
  "enabled": false,
  "name": "Security Scan on Python Save",
  "description": "Pythonファイル保存時にbanditでセキュリティ脆弱性をスキャン - 現在無効化（Windows環境では手動実行を推奨）",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "python -m bandit -r backend -f txt --severity-level medium --confidence-level medium",
    "timeout": 60
  }
}
